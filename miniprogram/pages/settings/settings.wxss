.page {
  min-height: 100vh;
  background-color: #F5F5F5;
  color: #333333;
  display: flex;
  flex-direction: column;
}

/* 自定义导航栏 */
.custom-nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  background-color: #165DFF;
  position: fixed;
  left: 0;
  z-index: 1000;
}

.nav-left {
  width: 80rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn {
  width: 40rpx;
  height: 40rpx;
  cursor: pointer;
}

.nav-title {
  flex: 1;
  text-align: center;
  color: white;
  font-size: 36rpx;
  font-weight: bold;
}

.nav-right {
  width: 80rpx;
  height: 100%;
}

.container {
  flex: 1;
  padding: 100rpx 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.section {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  color: #FF4D4F;
  background-color: white;
  border: 1px solid #FF4D4F;
  border-radius: 12rpx;
  margin-top: 32rpx;
}

.logout-btn:hover {
  background-color: rgba(255, 77, 79, 0.1);
}
