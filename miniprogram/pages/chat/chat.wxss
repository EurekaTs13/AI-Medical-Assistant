/* 侧边栏 */
.sidebar {
  position: fixed;
  left: 0;
  top: 0;
  height: 100vh;
  background-color: white;
  box-shadow: 2px 0 8px rgba(0, 0, 0, 0.1);
  z-index: 1001;
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.sidebar-content {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}

.sidebar-header {
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
}

.sidebar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.history-list {
  flex: 1;
  overflow-y: auto;
  padding-top: 16rpx;
}

.no-history {
  text-align: center;
  color: rgba(0, 0, 0, 0.45);
  font-size: 26rpx;
  padding: 60rpx 0;
}

.history-item {
  padding: 24rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 12rpx;
  background-color: rgba(0, 0, 0, 0.02);
  transition: background-color 0.2s ease;
}

.history-item:active {
  background-color: rgba(22, 93, 255, 0.1);
}

.history-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-time {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.45);
}

.user-info-section {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-top: 1px solid rgba(0, 0, 0, 0.08);
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-nickname {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* 遮罩层 */
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* 自定义导航栏 */
.custom-nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  background-color: #165DFF;
  position: fixed;
  left: 0;
  z-index: 1000;
}

.nav-left {
  width: 160rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.more-btn {
  width: 40rpx;
  height: 40rpx;
  cursor: pointer;
}

.new-chat-btn {
  width: 40rpx;
  height: 40rpx;
  cursor: pointer;
}

.nav-title {
  flex: 1;
  text-align: center;
  color: white;
  font-size: 36rpx;
  font-weight: bold;
}

.nav-right {
  width: 80rpx;
  height: 100%;
}

.page {
  height: 100vh;
  width: 100vw;
  background-color: #FFFFFF;
  color: #333333;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 顶部区域 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-phone {
  font-size: 26rpx;
  color: #333333;
}

.logout-btn {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.7);
  background: transparent;
  border: 1px solid rgba(0, 0, 0, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.logout-btn:hover {
  background: rgba(0, 0, 0, 0.05);
}

/* 中部居中 */
.center {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
  position: relative;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 0 20rpx;
  box-sizing: border-box;
  height: 100%;
}

/* 消息项 */
.message-item {
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-start;
}

/* 用户消息 */
.user-message {
  justify-content: flex-end;
}

.user-content {
  background-color: #E6F2FF;
  color: #333333;
  border-radius: 16rpx 16rpx 0 16rpx;
  max-width: 75%;
  min-width: auto;
  width: auto;
  align-self: flex-end;
  display: inline-block;
}

/* AI消息 */
.ai-message {
  justify-content: flex-start;
}

.ai-content {
  background-color: white;
  color: #333333;
  border-radius: 16rpx 16rpx 16rpx 0;
  max-width: 90%;
  align-self: flex-start;
  border: 1px solid rgba(0, 0, 0, 0.08);
}

/* 消息内容 */
.message-content {
  padding: 12rpx 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
  box-sizing: border-box;
}

/* 初始状态 */
.initial-state {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #333333;
}

.subtitle {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(0, 0, 0, 0.72);
}

/* 底部输入区域 */
.composer {
  position: relative;
  flex-shrink: 0;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(16px);
  border-top: 1px solid rgba(0, 0, 0, 0.06);
  z-index: 999;
  box-sizing: border-box;
}

.composer-inner {
  display: flex;
  flex-direction: column;
  padding: 14rpx;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.06);
  border: 1px solid rgba(0, 0, 0, 0.08);
  position: relative;
}

.input {
  width: 100%;
  min-height: 72rpx;
  max-height: 360rpx;
  font-size: 28rpx;
  color: #333333;
  padding: 12rpx 10rpx 80rpx 10rpx;
  line-height: 1.4;
  resize: none;
  overflow-y: auto;
}

.send {
  position: absolute;
  bottom: 14rpx;
  right: 14rpx;
  height: 60rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: white;
  background: #165DFF;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.send-hover {
  background: #0E47D9;
}

.hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(0, 0, 0, 0.45);
}

.answer-card {
  margin-top: 28rpx;
  width: 100%;
  max-width: 680rpx;
  text-align: left;
  padding: 22rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.06);
  border: 1px solid rgba(0, 0, 0, 0.08);
}

.answer-title {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.75);
  margin-bottom: 12rpx;
}

.answer-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #333333;
  white-space: pre-wrap;
  word-break: break-word;
}

/* 登录提示底部弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.login-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1001;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.login-modal-content {
  background-color: white;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx 24rpx 0 0;
}

.login-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-bottom: 40rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  border: none;
}

.login-btn:last-child {
  margin-bottom: 0;
}

.wechat-login {
  background-color: #07C160;
  color: white;
}

.wechat-login:active {
  background-color: #06AD56;
}

.cancel {
  background-color: #F5F5F5;
  color: #333333;
}

.cancel:active {
  background-color: #E5E5E5;
}